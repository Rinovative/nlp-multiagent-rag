# Hosted open-model generation (required for HF primary or fallback routes)
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_GENERATION_MODEL=Qwen/Qwen2.5-7B-Instruct

# Routing: auto, huggingface, or openai
GENERATION_PROVIDER=auto

# Local multilingual embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# Optional quota-controlled OpenAI generation
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_ENABLED=false
REDIS_URL=
OPENAI_QUOTA_KEY_PREFIX=nlp-rag:{openai-quota}

# Application bounds (1 MB = 1,048,576 bytes)
MAX_UPLOAD_FILE_MB=64
MAX_UPLOAD_TOTAL_MB=128
MAX_UPLOAD_FILES=10
MAX_INPUT_CHARACTERS=24000
MAX_OUTPUT_TOKENS=384
MAX_HISTORY_MESSAGES=10
RETRIEVAL_TOP_K=5
PROVIDER_TIMEOUT_SECONDS=45
